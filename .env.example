# Runtime
NODE_ENV=development
PUBLIC_APP_NAME=MyFace
PUBLIC_APP_URL=http://localhost:5173
API_URL=http://localhost:8787

# Database
DATABASE_URL=mysql://myface:myface@localhost:3306/myface

# Auth
SESSION_SECRET=replace-with-32-byte-secret
OAUTH_PROVIDER=local_dev
OAUTH_CLIENT_ID=replace-me
OAUTH_CLIENT_SECRET=replace-me
OAUTH_REDIRECT_URI=http://localhost:8787/auth/callback

# Node identity
MYFACE_NODE_NAME=JakeRoot
MYFACE_NODE_DOMAIN=localhost
MYFACE_NODE_FLAVOR=dev_collective
MYFACE_NODE_VISIBILITY=local_only
MYFACE_NODE_OWNER_HANDLE=jake

# User 0
MYFACE_USER_ZERO_HANDLE=jake
MYFACE_USER_ZERO_DISPLAY_NAME=Jason "Jake" Lawson
MYFACE_USER_ZERO_EMAIL=jslawson50@gmail.com

# Safety defaults
INVITES_REQUIRE_BACKEND_ADMISSION=true
NEW_USERS_DEFAULT_FRIEND_USER_ZERO=true
NEW_USERS_DEFAULT_TIER=new_arrival
FEDERATION_ENABLED=false
